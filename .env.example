# Copy to .env.local. Values for the shared dev setup are in Vercel: `vercel env pull .env.local`.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_REVALIDATE_SECRET=
# Read token (Viewer) del progetto Sanity: il dataset limita la lettura pubblica
# di alcuni tipi (es. caseStudy). Senza, /lavori resta vuota anche in dev.
SANITY_API_READ_TOKEN=
